diff --git a/supabase/migrations/20260619000000_create_lawyer_processes.sql b/supabase/migrations/20260619000000_create_lawyer_processes.sql
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/supabase/migrations/20260619000000_create_lawyer_processes.sql
@@ -0,0 +1,124 @@
+-- Social Jurídico — Processos DataJud/CNJ vinculados ao CRM
+-- Aplicar no Supabase do Social Jurídico antes de liberar /dashboard/advogado/processos.
+
+create table if not exists public.lawyer_processes (
+  id uuid primary key default gen_random_uuid(),
+  request_id uuid,
+  lawyer_id uuid not null references public.advogados(id) on delete cascade,
+  client_id uuid not null references public.crm_clients(id) on delete cascade,
+
+  numero_cnj text not null,
+  tribunal_codigo text,
+  tribunal_nome text,
+  tribunal_alias_datajud text,
+
+  classe text,
+  classe_codigo integer,
+  area text,
+  grau text,
+  sistema text,
+  formato text,
+  orgao_julgador text,
+  orgao_julgador_codigo integer,
+  data_ajuizamento text,
+  data_ultima_atualizacao timestamptz,
+  nivel_sigilo integer,
+  assuntos jsonb not null default '[]'::jsonb,
+
+  resumo_ia text,
+  resumo_ia_gerado boolean not null default false,
+
+  raw_payload jsonb not null default '{}'::jsonb,
+  external_registro_id uuid,
+  cliente_nome_snapshot text,
+  parte_contraria_snapshot text,
+
+  created_at timestamptz not null default now(),
+  updated_at timestamptz not null default now(),
+
+  constraint lawyer_processes_numero_cnj_digits check (numero_cnj ~ '^[0-9]{20}$'),
+  constraint lawyer_processes_unique_lawyer_cnj unique (lawyer_id, numero_cnj)
+);
+
+create table if not exists public.lawyer_process_parties (
+  id uuid primary key default gen_random_uuid(),
+  process_id uuid not null references public.lawyer_processes(id) on delete cascade,
+  lawyer_id uuid not null references public.advogados(id) on delete cascade,
+  client_id uuid references public.crm_clients(id) on delete set null,
+
+  name text not null,
+  party_type text not null default 'nao_informado'
+    check (party_type in ('pessoa_fisica', 'pessoa_juridica', 'nao_informado')),
+  document text,
+  role text,
+  is_client boolean not null default false,
+  is_opposing_party boolean not null default false,
+  source text not null default 'datajud',
+  raw_payload jsonb not null default '{}'::jsonb,
+  sort_order integer not null default 0,
+  created_at timestamptz not null default now()
+);
+
+create table if not exists public.lawyer_process_movements (
+  id uuid primary key default gen_random_uuid(),
+  process_id uuid not null references public.lawyer_processes(id) on delete cascade,
+  lawyer_id uuid not null references public.advogados(id) on delete cascade,
+
+  movement_date timestamptz,
+  description text not null,
+  movement_type text,
+  raw_payload jsonb not null default '{}'::jsonb,
+  sort_order integer not null default 0,
+  created_at timestamptz not null default now()
+);
+
+create table if not exists public.lawyer_process_warnings (
+  id uuid primary key default gen_random_uuid(),
+  process_id uuid not null references public.lawyer_processes(id) on delete cascade,
+  lawyer_id uuid not null references public.advogados(id) on delete cascade,
+
+  message text not null,
+  created_at timestamptz not null default now()
+);
+
+create index if not exists lawyer_processes_lawyer_created_idx
+  on public.lawyer_processes (lawyer_id, created_at desc);
+
+create index if not exists lawyer_processes_client_idx
+  on public.lawyer_processes (client_id, created_at desc);
+
+create index if not exists lawyer_process_parties_process_idx
+  on public.lawyer_process_parties (process_id, sort_order);
+
+create index if not exists lawyer_process_movements_process_idx
+  on public.lawyer_process_movements (process_id, sort_order);
+
+create index if not exists lawyer_process_warnings_process_idx
+  on public.lawyer_process_warnings (process_id, created_at);
+
+-- Opcional, mas recomendado: habilitar RLS para defesa em profundidade.
+-- As APIs do Next usam service role/supabaseAdmin, mas estas policies protegem acessos diretos autenticados.
+alter table public.lawyer_processes enable row level security;
+alter table public.lawyer_process_parties enable row level security;
+alter table public.lawyer_process_movements enable row level security;
+alter table public.lawyer_process_warnings enable row level security;
+
+drop policy if exists "lawyer_processes_owner_select" on public.lawyer_processes;
+create policy "lawyer_processes_owner_select"
+  on public.lawyer_processes for select
+  using (auth.uid() = lawyer_id);
+
+drop policy if exists "lawyer_process_parties_owner_select" on public.lawyer_process_parties;
+create policy "lawyer_process_parties_owner_select"
+  on public.lawyer_process_parties for select
+  using (auth.uid() = lawyer_id);
+
+drop policy if exists "lawyer_process_movements_owner_select" on public.lawyer_process_movements;
+create policy "lawyer_process_movements_owner_select"
+  on public.lawyer_process_movements for select
+  using (auth.uid() = lawyer_id);
+
+drop policy if exists "lawyer_process_warnings_owner_select" on public.lawyer_process_warnings;
+create policy "lawyer_process_warnings_owner_select"
+  on public.lawyer_process_warnings for select
+  using (auth.uid() = lawyer_id);

